# ═══════════════════════════════════════════
# Configuration - Data Mesh Self-Service
# ═══════════════════════════════════════════
# cp .env.example .env

# ── PostgreSQL (multi-domaine) ─────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=datamesh

# ── Domains ────────────────────────────
DOMAINS=sales,marketing,finance

# ── MinIO ──────────────────────────────
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=data-lake

# ── Airflow ────────────────────────────
AIRFLOW_HOST=localhost
AIRFLOW_PORT=8080

# ── Streamlit Portal ───────────────────
PORTAL_HOST=0.0.0.0
PORTAL_PORT=8501

# ── Governance ─────────────────────────
GOVERNANCE_DB=sqlite:///data/governance.db
